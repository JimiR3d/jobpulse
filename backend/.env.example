# Backend environment variables — local development only
# DO NOT COMMIT THIS FILE — it is in .gitignore

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# AI APIs (all free)
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Bot deployment mode:
#   "true"  = bot runs embedded in FastAPI (use on Render Starter or any always-on host)
#   "false" = bot runs in GitHub Actions (use on Render free tier)
START_TELEGRAM_BOT=true

# CORS — set to your Vercel URL in production
FRONTEND_URL=http://localhost:5173
ENV=development
